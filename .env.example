# ─── Application ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── MongoDB ─────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/moment-seekers
MONGODB_URI_PROD=mongodb+srv://<user>:<password>@cluster.mongodb.net/moment-seekers

# ─── JWT ─────────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRATION=7d

# ─── Admin Seed ──────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@momentseekerstudio.com
ADMIN_PASSWORD=Admin@1234

# ─── File Upload ─────────────────────────────────────────────────────────────────
UPLOAD_DEST=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/avif

# ─── Cloud Storage (optional — set STORAGE_PROVIDER to switch) ───────────────────
STORAGE_PROVIDER=local
# STORAGE_PROVIDER=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=moment-seekers-uploads

# ─── Stripe Payments ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── CORS ────────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:4200,https://momentseekerstudio.com

# ─── Rate Limiting ───────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
